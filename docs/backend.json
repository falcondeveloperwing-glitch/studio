{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Basic information about the business user.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "brandName": { "type": "string" },
        "personality": { "type": "string", "enum": ["Professional", "Friendly", "Luxury"] },
        "status": { "type": "string", "enum": ["free", "pro", "elite"] }
      },
      "required": ["email", "brandName"]
    },
    "Conversation": {
      "title": "Conversation Thread",
      "description": "An Instagram DM thread with a customer.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerUsername": { "type": "string" },
        "lastMessage": { "type": "string" },
        "status": { "type": "string", "enum": ["AI Handled", "Manual", "Escalated"] },
        "unread": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "avatarSeed": { "type": "string" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "A single message within a conversation.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["customer", "ai", "business"] },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "automated"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Automation": {
      "title": "Automation Workflow",
      "description": "A pre-defined trigger-action pair for the AI.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "trigger": { "type": "string" },
        "action": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Paused"] },
        "runs": { "type": "number" }
      }
    },
    "Analytics": {
      "title": "Analytics Snapshot",
      "description": "Aggregated metrics for the business dashboard.",
      "type": "object",
      "properties": {
        "recoveredSales": { "type": "number" },
        "totalConvs": { "type": "number" },
        "avgReplyTime": { "type": "number" },
        "csat": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/users/{userId}/conversations/{convId}": {
      "schema": "Conversation",
      "description": "List of active DM threads."
    },
    "/users/{userId}/conversations/{convId}/messages/{msgId}": {
      "schema": "Message",
      "description": "Individual messages in a thread."
    },
    "/users/{userId}/automations/{autoId}": {
      "schema": "Automation",
      "description": "AI triggers and responses."
    },
    "/users/{userId}/analytics/overview": {
      "schema": "Analytics",
      "description": "Dashboard performance data."
    }
  }
}